{
  "expo": {
    "name": "map",
    "slug": "map",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "map",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "map.cellr.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "map.cellr.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ],
      "config": {
        "googleMaps": {
          "apiKey": "YOUR_GOOGLE_MAPS_API_KEY"
        }
      }
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Your location is used to find nearby cell towers, calculate distances, and show compass bearing for antenna alignment."
        }
      ],
      [
        "expo-secure-store",
        {
          "configureAndroidBackup": false
        }
      ],
      [
        "@sentry/react-native",
        {
          "organization": "dearjournal",
          "project": "cellr"
        }
      ],
      [
        "expo-sensors",
        {
          "motionPermission": "Cellr reads the device magnetometer to show a live compass that points toward the selected cell tower."
        }
      ],
      "expo-video",
      [
        "expo-tracking-transparency",
        {
          "userTrackingPermission": "Cell Tower Map uses AppsFlyer to measure which ad or campaign brought you here, so we can improve the service. This choice does not affect tower data or any feature in the app."
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#111827"
        }
      ],
      [
        "react-native-adapty",
        {
          "replaceAndroidBackupConfig": true
        }
      ],
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "15.1"
          }
        }
      ],
      "expo-localization",
      "react-native-appsflyer"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "locales": {
      "ru": "./src/i18n/native/ru.json",
      "es-MX": "./src/i18n/native/es-MX.json",
      "pt-BR": "./src/i18n/native/pt-BR.json",
      "de": "./src/i18n/native/de.json",
      "fr": "./src/i18n/native/fr.json",
      "it": "./src/i18n/native/it.json",
      "sv": "./src/i18n/native/sv.json",
      "pl": "./src/i18n/native/pl.json",
      "nb": "./src/i18n/native/nb.json"
    },
    "extra": {
      "eas": {
        "projectId": "421cf184-ce1f-4aad-a869-3094226103c2"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/421cf184-ce1f-4aad-a869-3094226103c2"
    }
  }
}
